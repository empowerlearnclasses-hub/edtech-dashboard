# Copy this file to .env and fill in your own values.

PORT=4500
SESSION_SECRET=change-this-to-a-long-random-string

# ---- Database (required) ----
# For Supabase: Project Settings -> Database -> Connection string -> "Transaction" mode,
# then append ?sslmode=require if it isn't already there.
# For local development against a Postgres you run yourself, a plain
# postgresql://user:password@localhost:5432/dbname (no sslmode) also works.
DATABASE_URL=postgresql://postgres:yourpassword@db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require

# ---- File uploads: logo & QR code (optional) ----
# If both SUPABASE_URL and SUPABASE_SERVICE_KEY are set, uploaded logos/QR codes are
# stored in Supabase Storage instead of local disk — required on any host without a
# persistent disk (e.g. Render's free tier). Leave both blank to use local disk instead
# (fine for local development, or a host that does have persistent storage).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-not-the-anon-key
SUPABASE_STORAGE_BUCKET=uploads
