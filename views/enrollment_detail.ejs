<%- include('partials/header', { title: enrollment.person_name + ' — ' + (enrollment.course || 'Course'), user, active: 'students' }) %>

  <div class="breadcrumb"><a href="/students">Students</a> / <a href="/students/<%= enrollment.person_id %>"><%= enrollment.person_name %></a> / <%= enrollment.course || 'Enrollment' %></div>
  <div class="page-header">
    <div>
      <h1><%= enrollment.course || 'Course' %></h1>
      <p class="subtitle">
        <%= enrollment.person_code %> · <%= enrollment.person_name %> · Batch:
        <% if (enrollment.batches && enrollment.batches.length > 0) { %><% enrollment.batches.forEach((bt, i) => { %><% if (i > 0) { %>, <% } %><a href="/batches/<%= bt.id %>"><%= bt.name %></a><% }) %><% } else { %>—<% } %>
        · Sales Team: <%= enrollment.sales_staff_name || '—' %>
        · <% if (enrollment.status === 'dropout') { %><span class="badge badge-gray">Dropout</span><% } else { %><span class="badge badge-green">Active</span><% } %>
      </p>
    </div>
    <div style="display:flex; gap:8px;">
      <% if (canEditEnrollment) { %><a href="/enrollments/<%= enrollment.id %>/edit" class="btn btn-outline">Edit enrollment</a><% } %>
      <% if (user.role === 'admin' || user.role === 'staff') { %>
        <form method="POST" action="/enrollments/<%= enrollment.id %>/status">
          <input type="hidden" name="status" value="<%= enrollment.status === 'dropout' ? 'active' : 'dropout' %>">
          <button type="submit" class="btn btn-outline"><%= enrollment.status === 'dropout' ? 'Mark Active' : 'Mark Dropout' %></button>
        </form>
      <% } %>
      <% if (user.role === 'admin') { %>
        <form method="POST" action="/enrollments/<%= enrollment.id %>/delete" onsubmit="return confirm('Delete this enrollment and its fee/invoice/receipt history? This cannot be undone.');">
          <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (enrollment.status === 'dropout') { %>
  <div class="alert" style="background: #EEF0F3; color: var(--text-muted); margin-bottom: 20px;">This enrollment is marked <strong>Dropout</strong> — it's excluded from the dashboard's pending-fee totals and the Student list's active fee summary, but its fee/invoice/receipt history stays fully intact below.</div>
  <% } %>

  <% if (feePerms.viewAllocated || feePerms.viewCollected || feePerms.viewDue || feePerms.viewAgeing || feePerms.viewDuePercentage) { %>
  <div class="stat-grid">
    <% if (feePerms.viewAllocated) { %>
    <div class="stat-card ochre"><div class="label">Total Fee</div><div class="value">₹<%= enrollment.total_fee.toLocaleString('en-IN') %></div></div>
    <% } %>
    <% if (feePerms.viewCollected) { %>
    <div class="stat-card green"><div class="label">Fee Collected</div><div class="value">₹<%= enrollment.fee_collected.toLocaleString('en-IN') %></div></div>
    <% } %>
    <% if (feePerms.viewDue) { %>
    <div class="stat-card red"><div class="label">Fee Pending</div><div class="value">₹<%= enrollment.pending_fee.toLocaleString('en-IN') %></div></div>
    <% } %>
    <% if (feePerms.viewDuePercentage) { %>
    <div class="stat-card red"><div class="label">Fee Due %</div><div class="value"><%= enrollment.due_percentage %>%</div></div>
    <% } %>
    <% if (feePerms.viewAgeing) { %>
    <div class="stat-card"><div class="label">Due Ageing</div><div class="value"><%= enrollment.due_days === null ? '—' : enrollment.due_days + 'd' %></div><div class="sub">Since joined date</div></div>
    <% } %>
  </div>
  <% } %>

  <% if (feePerms.viewAllocated && feePerms.viewCollected) { %>
  <div class="card card-pad" style="margin-bottom: 24px;">
    <div style="display:flex; justify-content: space-between; font-size:12.5px; color:var(--text-muted); margin-bottom:4px;">
      <span>Collection progress</span>
      <span><%= enrollment.total_fee > 0 ? Math.min(100, Math.round((enrollment.fee_collected / enrollment.total_fee) * 100)) : 0 %>%</span>
    </div>
    <div class="progress-bar"><div class="fill" style="width: <%= enrollment.total_fee > 0 ? Math.min(100, Math.round((enrollment.fee_collected / enrollment.total_fee) * 100)) : 0 %>%;"></div></div>
  </div>
  <% } %>

  <% if (enrollment.remarks) { %>
  <div class="card card-pad" style="margin-bottom:24px;">
    <div class="form-section-title" style="margin-top:0;">Remarks</div>
    <div class="v" style="font-weight:400;"><%= enrollment.remarks %></div>
  </div>
  <% } %>

  <% if (canViewFee) { %>
  <div class="page-header" style="margin-bottom: 12px;">
    <div><h1 style="font-size:18px;">Fee Collection Details</h1><p class="subtitle">Linked to this enrollment — collected & pending totals above update automatically.</p></div>
  </div>

  <div class="section-flex">
    <div class="col" style="flex: 2 1 420px;">
      <% if (!feePerms.viewCollected) { %>
        <div class="card"><div class="empty-state" style="padding: 30px;">You don't have access to view fee collection entries. Ask your Admin to grant "Fee Collected" view access.</div></div>
      <% } else if (feeHistory.length === 0) { %>
        <div class="card"><div class="empty-state"><div class="big">₹</div>No fee collection entries recorded yet.</div></div>
      <% } else { %>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Date</th><th class="num">Amount</th><th>Collected By</th><th class="wrap">Notes</th><th>Receipt</th><th></th></tr></thead>
          <tbody>
            <% feeHistory.forEach(f => { %>
            <tr>
              <td data-label="Date"><%= f.collection_date %></td>
              <td class="num" data-label="Amount">₹<%= f.amount.toLocaleString('en-IN') %></td>
              <td data-label="Collected By"><%= f.collected_by_name || '—' %></td>
              <td class="wrap" data-label="Notes"><%= f.notes || '—' %></td>
              <td data-label="Receipt">
                <% if (f.receipt_id) { %>
                  <a href="/receipts/<%= f.receipt_id %>" class="btn btn-sm btn-outline">View</a>
                <% } else if (canCreateInvoices) { %>
                  <form method="POST" action="/fee-collections/<%= f.id %>/receipt">
                    <button type="submit" class="btn btn-sm btn-outline">Generate</button>
                  </form>
                <% } else { %>—<% } %>
              </td>
              <td>
                <% if (user.role === 'admin' || (user.role === 'staff' && feePerms.editCollected)) { %>
                <form method="POST" action="/enrollments/<%= enrollment.id %>/fees/<%= f.id %>/delete" onsubmit="return confirm('Remove this fee collection entry?');">
                  <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                </form>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <% if (feePerms.editCollected) { %>
    <div class="col" style="flex: 1 1 280px;">
      <div class="card card-pad">
        <strong style="display:block; margin-bottom: 14px;">Record fee collection</strong>
        <form method="POST" action="/enrollments/<%= enrollment.id %>/fees">
          <div class="form-group" style="margin-bottom:12px;">
            <label>Amount collected (₹) <span class="req">*</span></label>
            <input type="number" step="0.01" min="0.01" name="amount" required>
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>Collection date <span class="req">*</span></label>
            <input type="date" name="collection_date" required value="<%= new Date().toISOString().slice(0,10) %>">
          </div>
          <div class="form-group" style="margin-bottom:14px;">
            <label>Notes</label>
            <textarea name="notes" placeholder="e.g. Cash / UPI reference"></textarea>
          </div>
          <button type="submit" class="btn btn-ochre" style="width:100%; justify-content:center;">+ Add collection entry</button>
        </form>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>

  <% if (canViewInvoices) { %>
  <div class="page-header" style="margin-bottom: 12px;">
    <div><h1 style="font-size:18px;">Invoices</h1><p class="subtitle">Billing documents for this course — downloadable as PDF, identical whether opened on a computer or a phone.</p></div>
  </div>

  <div class="section-flex">
    <div class="col" style="flex: 2 1 420px;">
      <% if (invoices.length === 0) { %>
        <div class="card"><div class="empty-state"><div class="big">🧾</div>No invoices created yet.</div></div>
      <% } else { %>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Invoice #</th><th>Description</th><th class="num">Amount</th><th>Issue Date</th><th></th></tr></thead>
          <tbody>
            <% invoices.forEach(inv => { %>
            <tr onclick="window.location='/invoices/<%= inv.id %>'" style="cursor:pointer;">
              <td data-label="Invoice #"><strong><%= inv.invoice_number %></strong></td>
              <td data-label="Description" class="wrap"><%= inv.description %></td>
              <td class="num" data-label="Amount">₹<%= inv.amount.toLocaleString('en-IN') %></td>
              <td data-label="Issue Date"><%= inv.issue_date %></td>
              <td><a href="/invoices/<%= inv.id %>/pdf" target="_blank" class="btn btn-sm btn-outline" onclick="event.stopPropagation()">PDF</a></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <% if (canCreateInvoices) { %>
    <div class="col" style="flex: 1 1 280px;">
      <div class="card card-pad">
        <strong style="display:block; margin-bottom: 14px;">Create invoice</strong>
        <form method="POST" action="/enrollments/<%= enrollment.id %>/invoices">
          <div class="form-group" style="margin-bottom:12px;">
            <label>Description</label>
            <input type="text" name="description" value="<%= enrollment.course || 'Course Fee' %>">
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>Amount (₹) <span class="req">*</span></label>
            <input type="number" step="0.01" min="0.01" name="amount" required value="<%= enrollment.total_fee || '' %>">
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>Issue date <span class="req">*</span></label>
            <input type="date" name="issue_date" required value="<%= new Date().toISOString().slice(0,10) %>">
          </div>
          <div class="form-group" style="margin-bottom:12px;">
            <label>Due date</label>
            <input type="date" name="due_date">
          </div>
          <div class="form-group" style="margin-bottom:14px;">
            <label>Notes</label>
            <textarea name="notes"></textarea>
          </div>
          <button type="submit" class="btn btn-ochre" style="width:100%; justify-content:center;">+ Create invoice</button>
        </form>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>

<%- include('partials/footer') %>
