<%- include('partials/header', { title: 'Company Settings', user, active: 'settings' }) %>

  <div class="page-header">
    <div>
      <h1>Company Settings</h1>
      <p class="subtitle">Logo, address, and the Terms &amp; Conditions printed on every Invoice and Receipt Voucher.</p>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="card card-pad" style="max-width: 680px;">
    <form method="POST" action="/settings/company" enctype="multipart/form-data">

      <div class="form-section-title" style="margin-top:0;">Logo</div>
      <div style="display:flex; align-items:center; gap:16px; margin-bottom: 10px;">
        <% if (settings.logo_path) { %>
          <img src="<%= settings.logo_path.startsWith('http') ? settings.logo_path : '/uploads/' + settings.logo_path.split(/[\\/]/).pop() %>" alt="Logo" style="width:64px; height:64px; object-fit:contain; border:1px solid var(--border); border-radius:8px; background:#fff;">
        <% } else { %>
          <div style="width:64px; height:64px; border:1px dashed var(--border); border-radius:8px; display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:11px;">No logo</div>
        <% } %>
        <div style="flex:1;">
          <input type="file" name="logo" accept=".png,.jpg,.jpeg">
          <div class="hint">PNG or JPG, up to 3MB. Shown at the top-left of every invoice and receipt.</div>
        </div>
      </div>
      <% if (settings.logo_path) { %>
      <button type="submit" formaction="/settings/company/logo/remove" class="btn btn-sm btn-outline" style="margin-bottom: 10px;">Remove logo</button>
      <% } %>

      <div class="form-section-title">Company details</div>
      <div class="form-grid">
        <div class="form-group full">
          <label>Company / Institution name</label>
          <input type="text" name="company_name" value="<%= settings.company_name || '' %>">
        </div>
        <div class="form-group full">
          <label>Address</label>
          <textarea name="address"><%= settings.address || '' %></textarea>
        </div>
        <div class="form-group">
          <label>Phone</label>
          <input type="text" name="phone" value="<%= settings.phone || '' %>">
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" value="<%= settings.email || '' %>">
        </div>
        <div class="form-group">
          <label>GSTIN</label>
          <input type="text" name="gstin" value="<%= settings.gstin || '' %>">
        </div>
      </div>

      <div class="form-section-title">Invoice — Terms &amp; Conditions</div>
      <div class="form-grid">
        <div class="form-group full">
          <textarea name="invoice_terms" style="min-height:100px;" placeholder="e.g. Fee once paid is non-refundable. Payment due within 7 days of invoice date."><%= settings.invoice_terms || '' %></textarea>
        </div>
      </div>

      <div class="form-section-title">Bank Details (shown on Invoices)</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Account Holder Name</label>
          <input type="text" name="bank_account_name" value="<%= settings.bank_account_name || '' %>">
        </div>
        <div class="form-group">
          <label>Bank Name</label>
          <input type="text" name="bank_name" value="<%= settings.bank_name || '' %>">
        </div>
        <div class="form-group">
          <label>Account Number</label>
          <input type="text" name="bank_account_number" value="<%= settings.bank_account_number || '' %>">
        </div>
        <div class="form-group">
          <label>IFSC Code</label>
          <input type="text" name="bank_ifsc" value="<%= settings.bank_ifsc || '' %>">
        </div>
        <div class="form-group">
          <label>Branch</label>
          <input type="text" name="bank_branch" value="<%= settings.bank_branch || '' %>">
        </div>
      </div>

      <div class="form-section-title">Payment QR Code (shown on Invoices)</div>
      <div style="display:flex; align-items:center; gap:16px; margin-bottom: 10px;">
        <% if (settings.qr_code_path) { %>
          <img src="<%= settings.qr_code_path.startsWith('http') ? settings.qr_code_path : '/uploads/' + settings.qr_code_path.split(/[\\/]/).pop() %>" alt="QR Code" style="width:64px; height:64px; object-fit:contain; border:1px solid var(--border); border-radius:8px; background:#fff;">
        <% } else { %>
          <div style="width:64px; height:64px; border:1px dashed var(--border); border-radius:8px; display:flex; align-items:center; justify-content:center; color:var(--text-muted); font-size:11px;">No QR</div>
        <% } %>
        <div style="flex:1;">
          <input type="file" name="qr_code" accept=".png,.jpg,.jpeg">
          <div class="hint">Upload your bank/UPI app's QR code image directly (PNG or JPG, up to 3MB) — e.g. the one your bank gave you for your account.</div>
        </div>
      </div>
      <% if (settings.qr_code_path) { %>
      <button type="submit" formaction="/settings/company/qr-code/remove" class="btn btn-sm btn-outline" style="margin-bottom: 14px;">Remove QR code</button>
      <% } %>
      <div class="form-grid">
        <div class="form-group full">
          <label>UPI ID (used only if no QR code is uploaded above)</label>
          <input type="text" name="upi_id" placeholder="e.g. yourinstitute@okhdfcbank" value="<%= settings.upi_id || '' %>">
          <div class="hint">If you don't upload a QR code image, but do set a UPI ID here, every invoice instead gets an auto-generated QR code scoped to that invoice's exact amount. Leave both blank to skip the QR section entirely.</div>
        </div>
      </div>

      <div class="form-section-title">Receipt Voucher — Terms &amp; Conditions</div>
      <div class="form-grid">
        <div class="form-group full">
          <textarea name="receipt_terms" style="min-height:100px;" placeholder="e.g. This receipt is valid subject to realization of payment."><%= settings.receipt_terms || '' %></textarea>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save settings</button>
      </div>
    </form>
  </div>

<%- include('partials/footer') %>
