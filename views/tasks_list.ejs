<%- include('partials/header', { title: 'Tasks', user, active: 'tasks' }) %>

  <div class="page-header">
    <div>
      <h1>Tasks</h1>
      <p class="subtitle"><%= user.role === 'admin' ? 'Every task assigned across the institution.' : 'Tasks assigned to you.' %></p>
    </div>
    <% if (canManage) { %><a href="/tasks/new" class="btn btn-primary">+ New Task</a><% } %>
  </div>

  <form class="filters-bar" method="GET" action="/tasks">
    <div class="form-group">
      <label>Status</label>
      <select name="status">
        <option value="">All</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="done" <%= filters.status === 'done' ? 'selected' : '' %>>Done</option>
      </select>
    </div>
    <% if (canManage && staffList.length > 0) { %>
    <div class="form-group">
      <label>Assigned to</label>
      <select name="assigned_to">
        <option value="">Everyone</option>
        <% staffList.forEach(s => { %>
          <option value="<%= s.id %>" <%= String(filters.assigned_to) === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
    </div>
    <% } %>
    <button type="submit" class="btn btn-outline">Filter</button>
    <% if (filters.status || filters.assigned_to) { %><a href="/tasks" class="btn btn-outline">Clear</a><% } %>
  </form>

  <% if (tasks.length === 0) { %>
    <div class="card"><div class="empty-state">
      <div class="big">✅</div>
      <% if (canManage) { %>No tasks match the current filters.<% } else { %>No tasks assigned to you right now.<% } %>
    </div></div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <% if (canManage) { %><th>Assigned To</th><% } %>
          <th>Type</th>
          <th>Progress</th>
          <th>Due</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% tasks.forEach(t => { %>
        <tr onclick="window.location='/tasks/<%= t.id %>'" style="cursor:pointer;">
          <td data-label="Title"><strong><%= t.title %></strong></td>
          <% if (canManage) { %><td data-label="Assigned To"><%= t.assigned_to_name || '—' %></td><% } %>
          <td data-label="Type">
            <% if (t.scope_type === 'general') { %><span class="badge badge-gray">General</span>
            <% } else if (t.scope_type === 'batch') { %><span class="badge badge-gray">Batch: <%= t.batch_name || '—' %></span>
            <% } else { %><span class="badge badge-gray">Specific Students</span><% } %>
          </td>
          <td data-label="Progress">
            <% if (t.scope_type === 'general') { %>
              <% if (t.status === 'done') { %><span class="badge badge-green">Done</span><% } else { %><span class="badge badge-red">Pending</span><% } %>
            <% } else { %>
              <% const total = t.total_students || 0; const done = t.done_students || 0; %>
              <% if (total === 0) { %><span class="badge badge-gray">No students</span>
              <% } else if (done >= total) { %><span class="badge badge-green"><%= done %> / <%= total %> done</span>
              <% } else { %><span class="badge badge-red"><%= done %> / <%= total %> done</span><% } %>
            <% } %>
          </td>
          <td data-label="Due"><%= t.due_date || '—' %></td>
          <td><a href="/tasks/<%= t.id %>" class="btn btn-sm btn-outline">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

<%- include('partials/footer') %>
