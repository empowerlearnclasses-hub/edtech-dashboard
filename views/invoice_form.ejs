<%- include('partials/header', { title: 'Edit Invoice', user, active: 'students' }) %>

  <div class="breadcrumb"><a href="/enrollments/<%= student.id %>"><%= student.name %></a> / <a href="/invoices/<%= invoice.id %>"><%= invoice.invoice_number %></a> / Edit</div>
  <div class="page-header">
    <div>
      <h1>Edit <%= invoice.invoice_number %></h1>
      <p class="subtitle">For <%= student.name %> (<%= student.student_code %>)</p>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="card card-pad" style="max-width: 560px;">
    <form method="POST" action="/invoices/<%= invoice.id %>">
      <div class="form-grid">
        <div class="form-group full">
          <label>Description</label>
          <input type="text" name="description" value="<%= invoice.description || '' %>">
        </div>
        <div class="form-group">
          <label>Amount (₹) <span class="req">*</span></label>
          <input type="number" step="0.01" min="0" name="amount" required value="<%= invoice.amount %>">
        </div>
        <div class="form-group">
          <label>Issue Date <span class="req">*</span></label>
          <input type="date" name="issue_date" required value="<%= invoice.issue_date %>">
        </div>
        <div class="form-group">
          <label>Due Date</label>
          <input type="date" name="due_date" value="<%= invoice.due_date || '' %>">
        </div>
        <div class="form-group full">
          <label>Notes</label>
          <textarea name="notes"><%= invoice.notes || '' %></textarea>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a href="/invoices/<%= invoice.id %>" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>

<%- include('partials/footer') %>
