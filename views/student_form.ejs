<%- include('partials/header', { title: 'Add Student', user, active: 'students' }) %>

  <div class="breadcrumb"><a href="/students">Students</a> / New</div>
  <div class="page-header">
    <div>
      <h1>Add new student</h1>
      <p class="subtitle">A Student ID will be generated automatically on save. If this person already has one, use "+ Add another course" from their profile instead — this form is for a brand new person.</p>
    </div>
  </div>

  <% if (formValues.lead_id) { %>
  <div class="alert alert-success" style="margin-bottom:16px;">Converting a lead into an admission — Name, Phone, and Course are pre-filled from that lead. Complete the rest (Batch, Fee, Joined Date) and save to finish.</div>
  <% } %>
  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="card card-pad">
    <form method="POST" action="/students">
      <% if (formValues.lead_id) { %><input type="hidden" name="lead_id" value="<%= formValues.lead_id %>"><% } %>

      <div class="form-section-title">Basic details</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Name <span class="req">*</span></label>
          <input type="text" name="name" required value="<%= formValues.name || '' %>">
        </div>
        <% if (user.role !== 'sales_staff') { %>
        <div class="form-group">
          <label>Sales Team (Admission Credit) <span class="req">*</span></label>
          <% if (staffList.length > 0) { %>
          <select name="sales_staff_id" required>
            <option value="">Select Sales Team member</option>
            <% staffList.forEach(st => { %>
              <option value="<%= st.id %>" <%= String(formValues.sales_staff_id) === String(st.id) ? 'selected' : '' %>><%= st.name %></option>
            <% }) %>
          </select>
          <% } else { %>
          <div class="alert alert-error" style="margin:0;">No active Sales Team accounts exist yet. <a href="/users/new">Create one</a> before adding students — every student needs a Sales Team member credited for the admission.</div>
          <% } %>
        </div>
        <% } %>
        <div class="form-group full">
          <label>Student Batch(es) <span style="font-weight:400; color:var(--text-muted); font-size:12.5px;">— tick more than one if attending more than one batch (e.g. morning + evening)</span></label>
          <% if (batches.length > 0) { %>
          <div class="table-wrap" style="box-shadow:none; max-height:220px; overflow-y:auto;">
            <% batches.forEach(bt => { %>
              <div class="checkbox-row" style="padding:6px 10px;">
                <input type="checkbox" id="nbatch_<%= bt.id %>" name="batch_ids" value="<%= bt.id %>"
                  <%= formValues.batch_ids && [].concat(formValues.batch_ids).map(String).includes(String(bt.id)) ? 'checked' : '' %>>
                <label for="nbatch_<%= bt.id %>"><%= bt.name %></label>
              </div>
            <% }) %>
          </div>
          <div class="hint">Batches are managed under <a href="/batches">Batches</a>. Leave all unticked if no batch is assigned yet.</div>
          <% } else { %>
          <div class="alert alert-error" style="margin:0;">No batches exist yet. <a href="/batches/new">Create one</a> to assign this student to it.</div>
          <% } %>
        </div>
        <div class="form-group">
          <label>Course <span class="req">*</span></label>
          <select name="course_select" id="courseSelect" required onchange="toggleCourseOther()">
            <option value="">Select a course</option>
            <% courses.forEach(c => { %>
              <option value="<%= c %>" <%= formValues.course_select === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
            <option value="__other__" <%= formValues.course_select === '__other__' ? 'selected' : '' %>>Other (type below)</option>
          </select>
          <% if (courses.length === 0) { %>
          <div class="hint">No courses have been added yet.</div>
          <% } %>
        </div>
        <div class="form-group" id="courseOtherGroup" style="display:none;">
          <label>Course name <span class="req">*</span></label>
          <input type="text" name="course_other" id="courseOther" placeholder="Type the course name" value="<%= formValues.course_other || '' %>">
          <div class="hint"><a href="/courses">Manage the course list</a></div>
        </div>
        <div class="form-group">
          <label>Joined Date <span class="req">*</span></label>
          <input type="date" name="joined_date" required value="<%= formValues.joined_date || '' %>">
        </div>
      </div>

      <script>
        function toggleCourseOther() {
          const isOther = document.getElementById('courseSelect').value === '__other__';
          document.getElementById('courseOtherGroup').style.display = isOther ? 'flex' : 'none';
          document.getElementById('courseOther').required = isOther;
        }
        toggleCourseOther();
      </script>

      <div class="form-section-title">Contact details</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Phone No. (WhatsApp)</label>
          <input type="text" name="phone_whatsapp" value="<%= formValues.phone_whatsapp || '' %>">
        </div>
        <div class="form-group">
          <label>Phone No. (Call)</label>
          <input type="text" name="phone_call" value="<%= formValues.phone_call || '' %>">
        </div>
        <div class="form-group">
          <label>Mail ID</label>
          <input type="email" name="email" value="<%= formValues.email || '' %>">
        </div>
      </div>

      <div class="form-section-title">Location</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" value="<%= formValues.location || '' %>">
        </div>
        <div class="form-group">
          <label>District</label>
          <input type="text" name="district" value="<%= formValues.district || '' %>">
        </div>
        <div class="form-group">
          <label>State</label>
          <input type="text" name="state" value="<%= formValues.state || '' %>">
        </div>
        <div class="form-group">
          <label>Pincode</label>
          <input type="text" name="pincode" value="<%= formValues.pincode || '' %>">
        </div>
      </div>

      <div class="form-section-title">Occupation</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Job Role</label>
          <input type="text" name="job_role" value="<%= formValues.job_role || '' %>">
        </div>
        <div class="form-group">
          <label>Job / Business Name</label>
          <input type="text" name="job_business_name" value="<%= formValues.job_business_name || '' %>">
        </div>
        <div class="form-group">
          <label>Job Location</label>
          <input type="text" name="job_location" value="<%= formValues.job_location || '' %>">
        </div>
      </div>

      <% if (feePerms.viewAllocated || feePerms.editAllocated) { %>
      <div class="form-section-title">Fee details</div>
      <div class="form-grid">
        <div class="form-group">
          <label>Total Fee Allocated (₹) <% if (feePerms.editAllocated) { %><span class="req">*</span><% } %></label>
          <% if (feePerms.editAllocated) { %>
            <input type="number" step="0.01" min="0" name="total_fee" required value="<%= formValues.total_fee !== undefined && formValues.total_fee !== null ? formValues.total_fee : '' %>">
          <% } else { %>
            <input type="number" value="<%= formValues.total_fee || 0 %>" disabled style="background:#F3F4F6;">
            <div class="hint">You have view-only access to this field. Ask your Admin for edit rights to change it.</div>
          <% } %>
          <div class="hint">Collected amount & pending balance are tracked separately in Fee Collection and calculated automatically.</div>
        </div>
      </div>
      <% } %>

      <div class="form-section-title">Remarks</div>
      <div class="form-grid">
        <div class="form-group full">
          <textarea name="remarks"><%= formValues.remarks || '' %></textarea>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save student</button>
        <a href="/students" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>

<%- include('partials/footer') %>
