<%- include('partials/header', { title: isEdit ? 'Edit Lead' : 'Add Lead', user, active: 'leads' }) %>

  <div class="breadcrumb"><a href="/leads">Leads</a> / <%= isEdit ? 'Edit' : 'New' %></div>
  <div class="page-header">
    <div>
      <h1><%= isEdit ? 'Edit lead' : 'Add new lead' %></h1>
      <p class="subtitle"><%= isEdit ? lead.name : 'Capture a WhatsApp/call enquiry before it gets lost in a chat thread.' %></p>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="card card-pad">
    <form method="POST" action="<%= isEdit ? '/leads/' + lead.id : '/leads' %>">

      <div class="form-grid">
        <div class="form-group">
          <label>Date of Lead <span class="req">*</span></label>
          <input type="date" name="lead_date" required value="<%= lead.lead_date || '' %>">
        </div>
        <div class="form-group">
          <label>Phone Number <span class="req">*</span></label>
          <input type="text" name="phone" required value="<%= lead.phone || '' %>">
        </div>
        <div class="form-group">
          <label>Name <span class="req">*</span></label>
          <input type="text" name="name" required value="<%= lead.name || '' %>">
        </div>
        <% if (user.role !== 'sales_staff') { %>
        <div class="form-group">
          <label>Sales Team <span class="req">*</span></label>
          <% if (staffList.length > 0) { %>
          <select name="sales_staff_id" required>
            <option value="">Select Sales Team member</option>
            <% staffList.forEach(st => { %>
              <option value="<%= st.id %>" <%= String(lead.sales_staff_id) === String(st.id) ? 'selected' : '' %>><%= st.name %></option>
            <% }) %>
          </select>
          <% } else { %>
          <div class="alert alert-error" style="margin:0;">No active Sales Team accounts exist yet.</div>
          <% } %>
        </div>
        <% } %>
        <div class="form-group">
          <label>Course Looking For</label>
          <select name="course_select" id="courseSelect" onchange="toggleOther('courseSelect','courseOtherGroup')">
            <option value="">Not specified</option>
            <% courses.forEach(c => { %>
              <option value="<%= c %>" <%= lead.course_interested === c ? 'selected' : '' %>><%= c %></option>
            <% }) %>
            <option value="__other__" <%= (lead.course_interested && !courses.includes(lead.course_interested)) ? 'selected' : '' %>>Other (type below)</option>
          </select>
        </div>
        <div class="form-group" id="courseOtherGroup" style="display:none;">
          <label>Course name</label>
          <input type="text" name="course_other" id="courseOther" placeholder="Type the course name" value="<%= (lead.course_interested && !courses.includes(lead.course_interested)) ? lead.course_interested : '' %>">
        </div>
        <div class="form-group">
          <label>Place</label>
          <input type="text" name="place" value="<%= lead.place || '' %>">
        </div>
        <div class="form-group">
          <label>Job</label>
          <input type="text" name="job" value="<%= lead.job || '' %>">
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status_select" id="statusSelect" onchange="toggleOther('statusSelect','statusOtherGroup')">
            <% statuses.forEach(s => { %>
              <option value="<%= s %>" <%= (lead.status || 'New') === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
            <option value="__other__" <%= (lead.status && !statuses.includes(lead.status)) ? 'selected' : '' %>>Other (type below — adds a new status for everyone)</option>
          </select>
        </div>
        <div class="form-group" id="statusOtherGroup" style="display:none;">
          <label>New status name</label>
          <input type="text" name="status_other" id="statusOther" placeholder="e.g. Follow-up Later, Not Interested" value="<%= (lead.status && !statuses.includes(lead.status)) ? lead.status : '' %>">
        </div>
      </div>

      <script>
        function toggleOther(selectId, groupId) {
          const isOther = document.getElementById(selectId).value === '__other__';
          document.getElementById(groupId).style.display = isOther ? 'flex' : 'none';
        }
        toggleOther('courseSelect', 'courseOtherGroup');
        toggleOther('statusSelect', 'statusOtherGroup');
      </script>

      <div class="form-section-title">Notes</div>
      <div class="form-grid">
        <div class="form-group full">
          <label>Last Chat Notes</label>
          <textarea name="last_chat_notes" placeholder="What was last discussed"><%= lead.last_chat_notes || '' %></textarea>
        </div>
        <div class="form-group full">
          <label>Remarks</label>
          <textarea name="remarks"><%= lead.remarks || '' %></textarea>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save lead</button>
        <a href="<%= isEdit ? '/leads/' + lead.id : '/leads' %>" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>

<%- include('partials/footer') %>
