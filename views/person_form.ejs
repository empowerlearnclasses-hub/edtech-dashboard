<%- include('partials/header', { title: 'Edit ' + person.name, user, active: 'students' }) %>

  <div class="breadcrumb"><a href="/students">Students</a> / <a href="/students/<%= person.id %>"><%= person.name %></a> / Edit</div>
  <div class="page-header">
    <div>
      <h1>Edit <%= person.name %></h1>
      <p class="subtitle"><%= person.person_code %> — profile details only. To change a course, batch, or fee, edit that specific enrollment instead.</p>
    </div>
  </div>

  <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

  <div class="card card-pad" style="max-width: 640px;">
    <form method="POST" action="/students/<%= person.id %>">
      <div class="form-grid">
        <div class="form-group full">
          <label>Name <span class="req">*</span></label>
          <input type="text" name="name" required value="<%= person.name || '' %>">
        </div>
        <div class="form-group">
          <label>Phone (WhatsApp)</label>
          <input type="text" name="phone_whatsapp" value="<%= person.phone_whatsapp || '' %>">
        </div>
        <div class="form-group">
          <label>Phone (Call)</label>
          <input type="text" name="phone_call" value="<%= person.phone_call || '' %>">
        </div>
        <div class="form-group full">
          <label>Mail ID</label>
          <input type="email" name="email" value="<%= person.email || '' %>">
        </div>
        <div class="form-group">
          <label>Location</label>
          <input type="text" name="location" value="<%= person.location || '' %>">
        </div>
        <div class="form-group">
          <label>District</label>
          <input type="text" name="district" value="<%= person.district || '' %>">
        </div>
        <div class="form-group">
          <label>State</label>
          <input type="text" name="state" value="<%= person.state || '' %>">
        </div>
        <div class="form-group">
          <label>Pincode</label>
          <input type="text" name="pincode" value="<%= person.pincode || '' %>">
        </div>
        <div class="form-group">
          <label>Job Role</label>
          <input type="text" name="job_role" value="<%= person.job_role || '' %>">
        </div>
        <div class="form-group">
          <label>Job / Business Name</label>
          <input type="text" name="job_business_name" value="<%= person.job_business_name || '' %>">
        </div>
        <div class="form-group">
          <label>Job Location</label>
          <input type="text" name="job_location" value="<%= person.job_location || '' %>">
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a href="/students/<%= person.id %>" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>

<%- include('partials/footer') %>
